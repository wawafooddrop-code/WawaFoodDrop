rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isRestaurantOwner(restaurantId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.uid == request.auth.uid;
    }
    function isRider() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/riders/$(request.auth.uid));
    }
    function validOrderUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status','riderId','deliveredAt','completedAt','rejectionReason','updatedAt','commissionCounted']);
    }
    function validRiderUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status','riderId','riderName','deliveredAt','locationLat','locationLng','isOnline','updatedAt']);
    }

    // Restaurants: public read, owner/admin write
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isRestaurantOwner(restaurantId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Menu items: public read, restaurant owner writes
    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if isAuthenticated() &&
        isRestaurantOwner(request.resource.data.restaurantId);
    }

    // Orders: guest orders allowed for create; anyone can read single order by ID; authenticated users can read their own
    match /orders/{orderId} {
      allow create: if
        request.resource.data.isGuest == true ||
        (isAuthenticated() && request.resource.data.customerUid == request.auth.uid);
      allow read: if
        resource.data.isGuest == true ||
        resource.data.status == 'preparing' ||
        resource.data.status == 'ready_for_pickup' ||
        (isAuthenticated() && (
          resource.data.customerUid == request.auth.uid ||
          resource.data.riderId == request.auth.uid ||
          // Restaurant owner: check via restaurantId field, matching uid on the restaurant doc
          (resource.data.restaurantId != null &&
           get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.uid == request.auth.uid) ||
          // Fallback: direct field match (for orders that set restaurantOwnerUid)
          resource.data.restaurantOwnerUid == request.auth.uid ||
          isAdmin()));
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (resource.data.restaurantId != null &&
         get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.uid == request.auth.uid &&
         validOrderUpdate()) ||
        ((!(resource.data.keys().hasAll(['riderId'])) || resource.data.riderId == null || resource.data.riderId == request.auth.uid) && validRiderUpdate()));
      allow delete: if false;
    }

    // Order subcollection for guest lookups (by phone or order ID)
    match /orders/{orderId}/{subcollection}/{docId} {
      allow read, write: if false;
    }

    // Customers: own data only
    match /customers/{customerId} {
      allow read: if isOwner(customerId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(customerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Riders: own data only
    match /riders/{riderId} {
      allow read: if isOwner(riderId) || isAdmin();
      allow write: if isOwner(riderId) || isAdmin();
    }

    // Admins: read-only for auth check
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Config: read-only, admin-only write
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Guests: allow create/update for guest checkout (no auth required)
    // Only allow read/write of own phone record
    match /guests/{phone} {
      allow read, write: if true;
    }

    // Subscription plans: public read
    match /subscriptionPlans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin audit logs: admin-only read/write
    match /adminLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Rider payment requests: rider can create/read own, admin can read all and update
    match /riderPaymentRequests/{docId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.riderId == request.auth.uid);
      allow create: if isAuthenticated() && isRider();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Rider applications: any authenticated user can create (apply),
    // rider can read own application, admin can read all and update
    match /riderApplications/{docId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && request.auth.uid == docId);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Restaurant payment requests: admin manages, authenticated users can create
    match /paymentRequests/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Customer saved items subcollections (restaurants, menuItems)
    // Stored under /Customer_Saved/{customerId}/{subcollection}/{docId}
    match /Customer_Saved/{customerId}/{subcollection}/{docId} {
      allow read: if isOwner(customerId) || isAdmin();
      allow write: if isOwner(customerId) || isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
